# ====== 服务配置 ======
SERVER_PORT=8002

# ====== Milvus 向量数据库 ======
MILVUS_HOST=localhost:19530

# ====== PostgreSQL 元数据存储 ======
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=question_bank
PG_USERNAME=postgres
PG_PASSWORD=postgres

# ====== Redis 缓存 ======
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300
ENABLE_CACHE=true

# ====== 通义千问向量服务 ======
QW_HOST=http://127.0.0.1:8111/text_to_vector
QW_AUTH=

# ====== 推荐日志 ======
VERBOSE_RECOMMEND_LOG=false
